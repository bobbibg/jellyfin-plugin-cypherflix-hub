{
  "name": "jellyfin-plugin-cypherflix-hub-web",
  "version": "4.0.1",
  "private": true,
  "description": "Frontend bundle for the Cypherflix Hub Jellyfin plugin. Source-of-truth lives in TypeScript here; Vite produces a single hashed bundle that the C# build embeds as a resource in the plugin DLL.",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "watch": "vite build --watch --mode development",
    "typecheck": "tsc --noEmit",
    "lint": "eslint Web --ext .ts",
    "format": "prettier --write \"Web/**/*.{ts,css}\"",
    "gen:api": "openapi-typescript http://192.168.1.165:7960/openapi.json -o Web/types/api.generated.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "openapi-typescript": "^7.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  },
  "engines": {
    "node": ">=20"
  }
}
